# DreamLayer environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ------------------------------------------------------------------
# BLE device
# ------------------------------------------------------------------
# Leave blank to auto-scan for the nearest Frame device.
DREAMLAYER_DEVICE=

# ------------------------------------------------------------------
# Provider: "stub" (no API key needed) or "openai"
# ------------------------------------------------------------------
DREAMLAYER_PROVIDER=stub

# ------------------------------------------------------------------
# Timeouts & reconnect
# ------------------------------------------------------------------
DREAMLAYER_SCAN_TIMEOUT=6.0
DREAMLAYER_LOAD_TIMEOUT=12.0
DREAMLAYER_RECONNECT_BASE=1.0
DREAMLAYER_RECONNECT_MAX=30.0
DREAMLAYER_RECONNECT_TRIES=0

# ------------------------------------------------------------------
# Memory engine
# ------------------------------------------------------------------
DREAMLAYER_CONFIDENCE=0.60
DREAMLAYER_FALLBACK=Nothing found nearby.

# ------------------------------------------------------------------
# Logging: DEBUG | INFO | WARNING
# ------------------------------------------------------------------
DREAMLAYER_LOG_LEVEL=INFO

# ------------------------------------------------------------------
# OpenAI (only needed when DREAMLAYER_PROVIDER=openai)
# ------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_CONFIDENCE=0.85
