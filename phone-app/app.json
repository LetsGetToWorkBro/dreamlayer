{
  "expo": {
    "name": "DreamLayer",
    "slug": "dreamlayer",
    "version": "1.0.0",
    "scheme": "dreamlayer",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.letsgettoworkbro.dreamlayer",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#241F38"
      },
      "package": "com.letsgettoworkbro.dreamlayer"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "DreamLayer uses the camera to scan the pairing QR from your Mac mini."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#161D23"
        }
      ],
      "expo-localization",
      "expo-audio",
      "expo-image",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
