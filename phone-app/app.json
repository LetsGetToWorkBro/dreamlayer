{
  "expo": {
    "name": "DreamLayer",
    "slug": "dreamlayer",
    "version": "1.0.0",
    "scheme": "dreamlayer",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.letsgettoworkbro.dreamlayer",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["audio"],
        "NSLocalNetworkUsageDescription": "DreamLayer connects to your Mac mini Brain over your own local network, so your data stays between your devices instead of going through the cloud.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "package": "com.letsgettoworkbro.dreamlayer",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "monochromeImage": "./assets/adaptive-icon-monochrome.png",
        "backgroundColor": "#241F38"
      },
      "allowBackup": false,
      "softwareKeyboardLayoutMode": "resize",
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "DreamLayer uses the camera to scan the pairing QR from your Mac mini.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#161D23"
        }
      ],
      "expo-localization",
      [
        "expo-audio",
        {
          "recordAudioAndroid": false,
          "enableBackgroundPlayback": false
        }
      ],
      "expo-image",
      "expo-asset",
      [
        "./plugins/withAndroidNotificationBrand",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0B6B52"
        }
      ],
      "./plugins/withAndroidLanCleartext"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
